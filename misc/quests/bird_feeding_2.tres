[sub_resource type="Resource" id="Resource_gvk50"]
script = ExtResource("1_87q7k")
text = "Well done Pilot, now the birds are happy and will probably leave us alone! Also thank you for covering the statue up with seeds, now the birds will crap all over once again! Thats what the Rich Man deserves for treating us so badly!"
portrait = ExtResource("2_drecg")
metadata/_custom_type_script = "uid://u31paso7yk1x"

[sub_resource type="Resource" id="Resource_eda2c"]
script = ExtResource("1_87q7k")
text = "OH PILOT ARE YOU OKAY?! Hopefully the birds wont get too angry that they are not being fed…"
metadata/_custom_type_script = "uid://u31paso7yk1x"

[sub_resource type="Resource" id="Resource_wgkax"]
script = ExtResource("1_87q7k")
text = "Hey there Pilot, could you be kind enough to feed the birds again, ive acquired quite the following of birds since we last spoke, so now there are more birds to feed, Sorry! Also remember to put seeds on top of the statue at the park!"
portrait = ExtResource("2_drecg")
metadata/_custom_type_script = "uid://u31paso7yk1x"

