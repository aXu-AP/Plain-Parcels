[sub_resource type="Resource" id="Resource_wjb0r"]
script = ExtResource("1_ilk2w")
text = "Wow! Grandma's freshly baked cookies!
Thank you Mr. Pilot"
character = ExtResource("2_ilk2w")
metadata/_custom_type_script = "uid://u31paso7yk1x"

[sub_resource type="Resource" id="Resource_mc2jv"]
script = ExtResource("1_ilk2w")
text = "You were too slow! Now my grandson can't enjoy the cookies, he only likes them fresh out the oven! Now i have to make more..."
character = ExtResource("3_ci64h")
metadata/_custom_type_script = "uid://u31paso7yk1x"

[sub_resource type="Resource" id="Resource_ilk2w"]
script = ExtResource("1_ilk2w")
text = "Oh dear. My fragile cookies are now all just crumbles, he can't eat them like that! Now i have to make more..."
character = ExtResource("3_ci64h")
metadata/_custom_type_script = "uid://u31paso7yk1x"

[sub_resource type="Resource" id="Resource_bo7i5"]
script = ExtResource("1_ilk2w")
text = "Can you please deliver these freshly baked cookies to my grandson before they get cold?"
character = ExtResource("3_ci64h")
metadata/_custom_type_script = "uid://u31paso7yk1x"

