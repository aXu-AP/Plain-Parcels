[sub_resource type="Resource" id="Resource_u4ncy"]
script = ExtResource("1_pbqd3")
text = "WHAT ARE THESE?! \"Crazy Medication\"?! DID THE CHIEF SENT YOU?! It seems that he Still thinks im crazy, im not, im sure that Aliens are what destroyed the old village and not some volcanic activity! Maybe the chief is trying to hide truth! You know what, take this to him!
"
character = SubResource("Resource_wrt3j")
metadata/_custom_type_script = "uid://u31paso7yk1x"

