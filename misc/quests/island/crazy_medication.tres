[sub_resource type="Resource" id="Resource_rfc5k"]
script = ExtResource("1_pbqd3")
text = "Hey you, take this medication to the crazy guy living up north-east of the village. There is this crazy guy who believes that Aliens are coming to kidnap us, now the weird rods he put up are disturbing the wildlife here so it needs to stop.
"
character = SubResource("Resource_s2sn4")
metadata/_custom_type_script = "uid://u31paso7yk1x"

