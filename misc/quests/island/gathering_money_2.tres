[sub_resource type="Resource" id="Resource_p1wx2"]
script = ExtResource("1_s18kn")
text = "Hey there Pilot, I heard you helped my boyfriend gather some money for the anniversary gift for me. That was very kind of you! But now in turn I need help from you. Could you please collect coins for me too, so that I can afford him a gift too? Thanks!"
character = SubResource("Resource_f5v8s")
