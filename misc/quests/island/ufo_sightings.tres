[sub_resource type="Resource" id="Resource_x6not"]
script = ExtResource("1_qsion")
text = "You there! Have you seen weird things flying around in the sky?! They are watching us, even at this very moment! But dont worry! I have created a device that will block them out so they cant watch us anymore! Just Place these rods around the Island! AND BE QUICK ABOUT IT! WE DONT HAVE MUCH TIME!!!
"
character = SubResource("Resource_ksj4q")
metadata/_custom_type_script = "uid://u31paso7yk1x"

