; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addon_importer]

show_on_startup=false

[application]

config/name="Plain Parcels"
run/main_scene="uid://v2xnhkcjo41p"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://cew5swoj8vshb"
GameManager="*uid://1lw6tjyp1b5s"
DialogueBox="*uid://bn0sh6bm6kifd"
Gui="*uid://c4odctxla17ro"
Globals="*uid://mdya2eaix0nx"
Archipelago="*uid://c0ovofocoscyg"

[display]

window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray()

[file_customization]

folder_colors={
"res://actors/": "red",
"res://addons/": "gray",
"res://environment/": "teal",
"res://globals/": "gray",
"res://gui/": "green",
"res://materials/": "pink",
"res://misc/": "gray",
"res://music/": "purple",
"res://portraits/": "green"
}

[filesystem]

import/blender/enabled=false

[global_group]

quest_points=""

[importer_defaults]

scene={
"_subresources": {},
"animation/fps": 30,
"animation/import": true,
"animation/import_rest_as_RESET": false,
"animation/remove_immutable_tracks": true,
"animation/trimming": false,
"gltf/embedded_image_handling": 1,
"gltf/naming_version": 2,
"import_script/path": "",
"materials/extract": 1,
"materials/extract_format": 2,
"materials/extract_path": "res://materials",
"meshes/create_shadow_meshes": true,
"meshes/ensure_tangents": true,
"meshes/force_disable_compression": false,
"meshes/generate_lods": true,
"meshes/light_baking": 1,
"meshes/lightmap_texel_size": 0.2,
"nodes/apply_root_scale": true,
"nodes/import_as_skeleton_bones": false,
"nodes/root_name": "",
"nodes/root_scale": 1.0,
"nodes/root_script": null,
"nodes/root_type": "",
"nodes/use_name_suffixes": true,
"nodes/use_node_type_suffixes": true,
"skins/use_named_skins": true
}

